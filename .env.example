# Supabase — Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...          # "anon public" key (used by /api/stock)
SUPABASE_SERVICE_KEY=eyJ...       # "service_role" key (used by /api/webhook — never expose client-side)

# Stripe — Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from Stripe Dashboard → Webhooks → your endpoint → Signing secret

# Resend — resend.com → API Keys (optional — fulfillment emails)
RESEND_API_KEY=re_...
