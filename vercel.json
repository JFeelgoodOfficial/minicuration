{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.minicuration.com" }],
      "destination": "https://minicuration.com/:path*",
      "permanent": true
    }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook" },
    { "src": "/api/stock",   "dest": "/api/stock" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
